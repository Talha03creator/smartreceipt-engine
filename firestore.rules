rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() { return request.auth != null; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    function isValidUser(data) {
      return data.userId is string && data.email is string && data.email.matches('^[^@]+@[^@]+\\.[^@]+$');
    }

    match /users/{userId} {
      allow read, write: if isOwner(userId) && isValidId(userId);
    }

    match /companies/{companyId} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && incoming().userId == request.auth.uid && isValidId(companyId);
      allow update: if isSignedIn() && existing().userId == request.auth.uid && incoming().userId == request.auth.uid;
      allow delete: if isSignedIn() && existing().userId == request.auth.uid;
    }

    match /receipts/{receiptId} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && incoming().userId == request.auth.uid && isValidId(receiptId) && exists(/databases/$(database)/documents/companies/$(incoming().companyId));
      allow update: if isSignedIn() && existing().userId == request.auth.uid && incoming().userId == request.auth.uid && incoming().companyId == existing().companyId;
      allow delete: if isSignedIn() && existing().userId == request.auth.uid;
    }
  }
}
